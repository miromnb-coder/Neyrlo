{
  "expo": {
    "name": "Neyrlo",
    "slug": "neyrlo",
    "scheme": "neyrlo",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#55633F"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Neyrlo käyttää sijaintiasi näyttääkseen lähellä olevia tavaroita. Tarkkaa noutopaikkaa ei näytetä muille."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Neyrlo käyttää kuviasi, jotta voit lisätä tavaran kuvat ilmoitukseen.",
          "cameraPermission": "Neyrlo käyttää kameraa, jotta voit ottaa kuvia tavarasta ilmoitusta varten."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#55633F",
          "defaultChannel": "default"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.miromnbcoder.neyrlo"
    },
    "android": {
      "package": "com.miromnbcoder.neyrlo",
      "adaptiveIcon": {
        "backgroundColor": "#55633F"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
